# Copy to .env and fill in. Never commit .env.
DATABASE_URL=postgresql+psycopg://astor:astor@localhost:5432/astor

# Embeddings: pluggable. dev = offline deterministic (no API, for local runs/tests).
# Swap to a real provider (voyage / openai) before trusting match quality.
EMBEDDINGS_PROVIDER=dev
EMBEDDING_DIM=1024
VOYAGE_API_KEY=
OPENAI_API_KEY=

# LLM extraction (used for PDF/HTML catalogs; CSV/XLSX need no LLM)
ANTHROPIC_API_KEY=

# Shopify house-catalog feed (Dev Dashboard app, post-2026 auth).
# SHOP_DOMAIN is the *.myshopify.com handle, NOT the public .us domain.
# Provide EITHER a legacy static token OR the Dev Dashboard client pair.
SHOPIFY_SHOP_DOMAIN=
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
# SHOPIFY_ADMIN_TOKEN=          # only if you have a legacy admin-created app
SHOPIFY_API_VERSION=2026-01
# SHOPIFY_MPN_METAFIELD=custom.mpn
# SHOPIFY_SPECS_METAFIELD_NAMESPACE=specs

# Matching thresholds
EQUIV_EXACT_THRESHOLD=0.92
EQUIV_SUBSTITUTE_THRESHOLD=0.80
EQUIV_CANDIDATES=20

LOG_LEVEL=INFO
